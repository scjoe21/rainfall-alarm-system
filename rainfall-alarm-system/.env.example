KMA_API_KEY=your_api_key_here
KMA_APIHUB_KEY=your_apihub_key_here
PORT=3000
MOCK_MODE=true
KMA_DAILY_LIMIT=10000

# 1시간 예측: API허브 VSRT(nph-dfs_vsrt_grd) 전국 1회 우선. 미승인 시 false로 두면 공공 초단기예보만 사용
# KMA_VSRT_ENABLED=false
# VSRT_MIN_REFRESH_MS=480000

# Cloudflare Worker 프록시 (기상청 API 한국 PoP 경유, 필수)
# worker/ 폴더에서 wrangler deploy 후 URL 설정
# CLOUDFLARE_WORKER_URL=https://rainfall-alarm-proxy.xxx.workers.dev
# CLOUDFLARE_PROXY_TOKEN=your_proxy_token

# 여러 도메인은 쉼표로 구분. 미설정 시 localhost:5173만 허용
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
